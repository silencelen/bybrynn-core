<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <security>
            <requestFiltering>
                <hiddenSegments>
                    <add segment="admin_debug.log" />
                    <add segment="deliverables" />
                </hiddenSegments>
                <fileExtensions>
                    <add fileExtension=".log" allowed="false" />
                </fileExtensions>
            </requestFiltering>
        </security>
        <httpProtocol>
            <customHeaders>
                <add name="X-Content-Type-Options" value="nosniff" />
                <add name="X-Frame-Options" value="DENY" />
                <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
                <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' https://unpkg.com https://cdn.jsdelivr.net 'unsafe-inline'; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'" />
            </customHeaders>
        </httpProtocol>
        <staticContent>
            <mimeMap fileExtension=".webp" mimeType="image/webp" />
        </staticContent>
        <httpErrors>
            <remove statusCode="405" subStatusCode="-1" />
            <remove statusCode="403" subStatusCode="-1" />
            <remove statusCode="404" subStatusCode="-1" />
            <remove statusCode="401" subStatusCode="-1" />
            <error statusCode="401" prefixLanguageFilePath="" path="https://bybrynn.com/uhoh" responseMode="Redirect" />
            <error statusCode="404" prefixLanguageFilePath="" path="https://bybrynn.com/uhoh" responseMode="Redirect" />
            <error statusCode="403" prefixLanguageFilePath="" path="https://bybrynn.com/uhoh" responseMode="Redirect" />
            <error statusCode="405" prefixLanguageFilePath="" path="https://bybrynn.com/uhoh" responseMode="Redirect" />
        </httpErrors>
        <rewrite>
            <rules>
                    <rule name="SubmissionsPrettyUrl" stopProcessing="true">
                    <match url="^submissions/?$" ignoreCase="true" />
                    <action type="Rewrite" url="submissions.php" appendQueryString="true" />
                </rule>
            </rules>
        </rewrite>
        <defaultDocument>
            <files>
                <add value="index.php" />
            </files>
        </defaultDocument>
    </system.webServer>
</configuration>
